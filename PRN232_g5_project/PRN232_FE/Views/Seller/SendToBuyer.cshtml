cshtml PRN232_FE\Views\Seller\SendToBuyer.cshtml
@{
    ViewData["Title"] = "Gửi Feedback cho Buyer";
}
<h2>@ViewData["Title"]</h2>

<form id="stbForm">
    <label>BuyerId: <input type="number" id="buyerId" required /></label><br />
    <label>ProductId: <input type="number" id="productId" required /></label><br />
    <label>Message:<br /><textarea id="message" rows="4" cols="50" required></textarea></label><br />
    <label>Images: <input type="file" id="images" multiple accept="image/*" /></label><br />
    <button type="submit">Gửi</button>
</form>

<div id="result"></div>

<script src="~/js/feedback.js"></script>
<script>
document.getElementById('stbForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = new FormData();
    form.append('BuyerId', document.getElementById('buyerId').value);
    form.append('ProductId', document.getElementById('productId').value);
    form.append('Message', document.getElementById('message').value);
    const files = document.getElementById('images').files;
    for (let i = 0; i < files.length; i++) form.append('images', files[i]);

    const res = await postFormData('/api/SellerToBuyerFeedback', form);
    const text = await res.text();
    if (res.ok) document.getElementById('result').innerText = 'Gửi thành công: ' + text;
    else document.getElementById('result').innerText = 'Lỗi: ' + text;
});
</script>