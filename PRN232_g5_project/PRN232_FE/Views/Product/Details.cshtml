@model PRN232_FE.Models.ProductViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="container" style="max-width: 1000px; margin: 40px auto; padding: 0 16px;">
    <div style="display: flex; gap: 40px; flex-wrap: wrap;">
        <!-- Left: Image -->
        <div style="flex: 1; min-width: 300px;">
            <div style="background-color: #f7f7f7; border-radius: 8px; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; overflow: hidden; position: relative;">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                {
                    <img src="@Model.ThumbnailUrl" alt="@Model.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                }
                else
                {
                    <i class="bi bi-box" style="font-size: 100px; color: #ccc;"></i>
                }
            </div>
        </div>

        <!-- Right: Details -->
        <div style="flex: 1; min-width: 300px;">
            <h1 style="font-size: 24px; font-weight: bold; margin-bottom: 8px; color: #333;">@Model.Title</h1>
            <p style="font-size: 14px; color: #707070; margin-bottom: 24px;">Condition: <span style="font-weight: bold; color: #333;">New with tags</span></p>

            <div style="background-color: #f7f7f7; padding: 16px; border-radius: 8px; margin-bottom: 24px;">
                <div style="font-size: 14px; color: #707070;">Price:</div>
                <div style="font-size: 32px; font-weight: bold; color: #333;">US $@Model.Price.ToString("0.00")</div>
                
                <div style="margin-top: 24px; display: flex; flex-direction: column; gap: 12px;">
                    <a href="/Product/Checkout/@Model.Id" style="display: block; text-align: center; background-color: #3665f3; color: white; border: none; border-radius: 24px; padding: 12px 24px; font-size: 16px; font-weight: bold; cursor: pointer; text-decoration: none;">Buy It Now</a>
                    <button style="background-color: #333; color: white; border: none; border-radius: 24px; padding: 12px 24px; font-size: 16px; font-weight: bold; cursor: pointer;">Add to cart</button>
                    <button style="background-color: white; color: #3665f3; border: 1px solid #3665f3; border-radius: 24px; padding: 12px 24px; font-size: 16px; font-weight: bold; cursor: pointer;">Add to Watchlist</button>
                </div>
            </div>

            <!-- Seller Info -->
            <div style="border: 1px solid #e5e5e5; padding: 16px; border-radius: 8px;">
                <h3 style="font-size: 16px; font-weight: bold; margin-bottom: 8px;">Seller information</h3>
                <div style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: #333;">
                    <i class="bi bi-person-circle" style="font-size: 24px; color: #707070;"></i>
                    <span style="font-weight: bold;">Seller ID: @Model.SellerId</span>
                    <span style="color: #707070;">(100% positive feedback)</span>
                </div>
                <hr style="border-top: 1px solid #e5e5e5; margin: 12px 0;" />
                <a href="#" style="color: #3665f3; text-decoration: none; font-size: 14px; display: block; margin-bottom: 8px;">Contact seller</a>
                <a href="#" style="color: #3665f3; text-decoration: none; font-size: 14px; display: block;">See other items</a>
            </div>
            
            <!-- Description -->
            <div style="margin-top: 24px;">
                <h3 style="font-size: 16px; font-weight: bold; margin-bottom: 8px; border-bottom: 1px solid #e5e5e5; padding-bottom: 8px;">Item description</h3>
                <p style="font-size: 14px; color: #333; line-height: 1.5;">@Model.Description</p>
                <div style="font-size: 12px; color: #707070;">Listed on: @Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>
</div>
