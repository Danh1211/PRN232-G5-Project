@model PRN232_FE.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container" style="max-width: 800px; margin: 40px auto; padding: 0 16px;">
    <h1 style="font-size: 28px; font-weight: bold; margin-bottom: 24px; color: #333;">Checkout</h1>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" style="font-size: 14px; margin-bottom: 24px;">
            @TempData["ErrorMessage"]
        </div>
    }

    <form action="/Product/ConfirmOrder" method="post">
        <input type="hidden" name="productId" value="@Model.Product.Id" />
        <div style="display: flex; gap: 40px; flex-wrap: wrap;">
            
            <!-- Left: Order Form -->
            <div style="flex: 2; min-width: 300px;">
                <div style="border: 1px solid #e5e5e5; padding: 24px; border-radius: 8px; margin-bottom: 24px;">
                    <h3 style="font-size: 18px; font-weight: bold; margin-bottom: 16px;">Ship to</h3>
                    @if (Model.Addresses != null && Model.Addresses.Any())
                    {
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            @foreach (var addr in Model.Addresses)
                            {
                                <label style="display: flex; gap: 12px; padding: 12px; border: 1px solid @(Model.SelectedAddressId == addr.Id ? "#3665f3" : "#e5e5e5"); border-radius: 8px; cursor: pointer;">
                                    <input type="radio" name="addressId" value="@addr.Id" @(Model.SelectedAddressId == addr.Id ? "checked" : "") style="margin-top: 4px;" />
                                    <div style="font-size: 14px; color: #333; line-height: 1.5;">
                                        <div style="font-weight: bold;">@addr.Street</div>
                                        <div>@addr.City, @addr.Country</div>
                                        <div style="color: #707070;">@addr.Phone</div>
                                    </div>
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning" style="font-size: 14px;">
                            You don't have a shipping address. Please <a href="/Auth/Profile">add one in your profile</a> first.
                        </div>
                        <input type="hidden" name="addressId" value="0" />
                    }
                </div>

                <div style="border: 1px solid #e5e5e5; padding: 24px; border-radius: 8px;">
                    <h3 style="font-size: 18px; font-weight: bold; margin-bottom: 16px;">Payment method</h3>
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <label style="display: flex; align-items: center; gap: 12px; padding: 12px; border: 1px solid #3665f3; border-radius: 8px; cursor: pointer;">
                            <input type="radio" name="paymentMethod" value="credit_card" checked />
                            <span style="font-size: 14px; font-weight: bold; color: #333;">Credit Card</span>
                        </label>
                        <label style="display: flex; align-items: center; gap: 12px; padding: 12px; border: 1px solid #e5e5e5; border-radius: 8px; cursor: pointer;">
                            <input type="radio" name="paymentMethod" value="paypal" />
                            <span style="font-size: 14px; font-weight: bold; color: #333;">PayPal</span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Right: Order Summary -->
            <div style="flex: 1; min-width: 250px;">
                <div style="border: 1px solid #e5e5e5; padding: 24px; border-radius: 8px; background-color: #f7f7f7;">
                    <h3 style="font-size: 18px; font-weight: bold; margin-bottom: 16px;">Order Summary</h3>
                    
                    <div style="display: flex; gap: 12px; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid #e5e5e5;">
                        <div style="width: 60px; height: 60px; background-color: #fff; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                            @if (!string.IsNullOrEmpty(Model.Product.ThumbnailUrl))
                            {
                                <img src="@Model.Product.ThumbnailUrl" alt="@Model.Product.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <i class="bi bi-box" style="color: #ccc; font-size: 24px;"></i>
                            }
                        </div>
                        <div>
                            <div style="font-size: 14px; font-weight: bold; color: #333; margin-bottom: 4px;">@Model.Product.Title</div>
                            <div style="font-size: 14px; color: #707070;">Qty: 1</div>
                        </div>
                    </div>

                    <div style="display: flex; justify-content: space-between; font-size: 14px; color: #333; margin-bottom: 8px; padding-bottom: 8px; border-bottom: 1px solid #e5e5e5;">
                        <span>Wallet Balance</span>
                        <span style="font-weight: bold; color: @(Model.UserBalance >= Model.Product.Price ? "#008a00" : "#e53238");">$@Model.UserBalance.ToString("0.00")</span>
                    </div>

                    <div style="display: flex; justify-content: space-between; font-size: 14px; color: #333; margin-bottom: 8px;">
                        <span>Item</span>
                        <span>$@Model.Product.Price.ToString("0.00")</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 14px; color: #333; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid #e5e5e5;">
                        <span>Shipping</span>
                        <span>Free</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 18px; font-weight: bold; color: #333; margin-bottom: 24px;">
                        <span>Order total</span>
                        <span>$@Model.Product.Price.ToString("0.00")</span>
                    </div>

                    <button type="submit" class="ebay-btn ebay-btn-primary" style="width: 100%; font-size: 16px; padding: 12px;">Confirm and pay</button>
                    <p style="font-size: 12px; color: #707070; text-align: center; margin-top: 12px;">By hitting "Confirm and pay", you agree to the Terms of Use.</p>
                </div>
            </div>
        </div>
    </form>
</div>
