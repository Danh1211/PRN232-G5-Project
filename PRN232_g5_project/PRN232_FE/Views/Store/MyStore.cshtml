@model PRN232_FE.Models.StoreDashboardViewModel
@{
    ViewData["Title"] = Model.StoreName ?? "My Store";
}

<div class="container" style="max-width: 1000px; margin: 40px auto; padding: 0 16px;">
    
    <!-- Store Banner & Header -->
    <div style="border-radius: 12px; overflow: hidden; border: 1px solid #e5e5e5; background-color: #fff; margin-bottom: 32px;">
        @if (!string.IsNullOrEmpty(Model.BannerImageUrl))
        {
            <div style="height: 200px; background-color: #ddd; background-image: url('@Model.BannerImageUrl'); background-size: cover; background-position: center;"></div>
        }
        else
        {
            <div style="height: 120px; background: linear-gradient(90deg, #3665f3 0%, #002d9c 100%);"></div>
        }
        
        <div style="padding: 24px; position: relative;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <h1 style="font-size: 32px; font-weight: bold; margin: 0 0 8px 0; color: #333;">@Model.StoreName</h1>
                    <div style="font-size: 14px; font-weight: bold; margin-bottom: 8px; display: inline-block; padding: 4px 12px; border-radius: 12px; background-color: @(Model.ReputationScore < 0 ? "#fce4e4" : "#e6f4ea"); color: @(Model.ReputationScore < 0 ? "#cc0000" : "#137333");">
                        @(Model.ReputationScore < 0 ? "⚠️" : "⭐") Reputation: @Model.ReputationScore
                    </div>
                    <p style="font-size: 16px; color: #555; margin: 0; max-width: 600px;">@Model.Description</p>
                </div>
                <a href="/Auth/Profile" style="padding: 8px 16px; border: 1px solid #3665f3; color: #3665f3; text-decoration: none; border-radius: 20px; font-weight: bold; background: transparent;">Back to Profile</a>
            </div>
        </div>
    </div>

    <!-- Products Section -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 style="font-size: 24px; font-weight: bold; margin: 0;">My Products (@Model.Products.Count)</h2>
        @if (Model.ReputationScore < 0)
        {
            <div style="font-size: 14px; color: #cc0000; font-weight: bold; padding: 10px 16px; background-color: #fce4e4; border-radius: 8px;">
                ⚠️ Your reputation is too low to add new products.
            </div>
        }
        else
        {
            <a href="/Store/AddProduct" style="background-color: #3665f3; color: white; padding: 10px 24px; border-radius: 20px; font-weight: bold; text-decoration: none;">+ Add New Product</a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="margin-bottom: 24px;">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" style="margin-bottom: 24px;">@TempData["ErrorMessage"]</div>
    }

    <!-- Products Grid -->
    @if (Model.Products.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
            @foreach (var product in Model.Products)
            {
                <div style="border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; background-color: white; transition: box-shadow 0.2s; display: flex; flex-direction: column;">
                    <div style="height: 200px; background-color: #f7f7f7; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(product.ThumbnailUrl))
                        {
                            <img src="@product.ThumbnailUrl" alt="@product.Title" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                        }
                        else
                        {
                            <span style="color: #999;">No Image</span>
                        }
                    </div>
                    
                    <div style="padding: 16px; display: flex; flex-direction: column; flex-grow: 1;">
                        <h3 style="font-size: 16px; margin: 0 0 8px 0; font-weight: bold; color: #333; line-height: 1.4;">
                            @product.Title
                        </h3>
                        <div style="font-size: 20px; font-weight: bold; color: #333; margin-bottom: 16px;">
                            $@product.Price.ToString("0.00")
                        </div>
                        
                        <div style="margin-top: auto; display: flex; gap: 8px;">
                            <a href="/Product/Details/@product.Id" style="flex: 1; text-align: center; padding: 8px; border: 1px solid #ccc; color: #333; text-decoration: none; border-radius: 20px; font-size: 14px; font-weight: bold;">View</a>
                            <!-- Edit/Delete could go here -->
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 60px 20px; border: 1px dashed #ccc; border-radius: 12px; background-color: #fcfcfc;">
            <div style="font-size: 48px; margin-bottom: 16px; color: #ccc;">📦</div>
            <h3 style="font-size: 20px; color: #333; margin-bottom: 8px;">No products yet</h3>
            <p style="color: #666; margin-bottom: 24px;">Start listing items to show them to buyers on eBay Clone.</p>
        </div>
    }
</div>
