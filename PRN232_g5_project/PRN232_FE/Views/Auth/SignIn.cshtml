@model PRN232_FE.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["ShowTellUs"] = true;
    ViewData["ShowTellUs"] = false;
}

<div class="auth-card">
    <h1 class="auth-title">Sign in to your account</h1>
    <p class="auth-subtitle">New to eBay? <a href="/Auth/SignUp">create an account</a></p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="font-size: 14px; margin-bottom: 16px;">
            @TempData["SuccessMessage"]
        </div>
    }
    
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger" style="font-size: 14px; margin-bottom: 16px;">
            @ViewBag.ErrorMessage
        </div>
    }

    <form action="/Auth/SignIn" method="post">
        <div class="ebay-form-group">
            <input type="text" id="UsernameOrEmail" name="UsernameOrEmail" class="ebay-input" placeholder=" " value="@Model?.UsernameOrEmail" required />
            <label for="UsernameOrEmail" class="ebay-floating-label">Email or username</label>
        </div>
        
        <div class="ebay-form-group">
            <input type="password" id="Password" name="Password" class="ebay-input" placeholder=" " required />
            <label for="Password" class="ebay-floating-label">Password</label>
        </div>

        <button type="submit" class="ebay-btn ebay-btn-primary">Sign in</button>
    </form>

    <div class="ebay-divider">
        <span class="ebay-divider-text">or</span>
    </div>

    <button type="button" class="ebay-btn ebay-btn-social">
        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" />
        Continue with Google
    </button>
    
    <button type="button" class="ebay-btn ebay-btn-social">
        <img src="https://upload.wikimedia.org/wikipedia/commons/f/fa/Apple_logo_black.svg" alt="Apple" />
        Continue with Apple
    </button>
    
    <button type="button" class="ebay-btn ebay-btn-social">
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b8/2021_Facebook_icon.svg" alt="Facebook" />
        Continue with Facebook
    </button>

    <div class="ebay-checkbox" style="margin-top: 24px;">
        <input type="checkbox" id="stay-signed-in" checked />
        <label for="stay-signed-in">
            Stay signed in<br />
            <span style="font-size: 12px; color: var(--ebay-gray);">Using a public or shared device? Uncheck to protect your account. <a href="#">Learn more</a></span>
        </label>
    </div>
</div>
