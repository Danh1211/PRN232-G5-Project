@model PRN232_FE.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

@if (ViewBag.IsLoggedIn == true)
{
    <div class="alert alert-success mt-3" style="font-size: 14px; text-align: center;">
        Welcome Back! You have successfully logged in.
    </div>
}

<!-- Hero Banner -->
<div class="ebay-hero" style="background-color: #f7f7f7; padding: 40px; border-radius: 8px; margin-top: 16px; margin-bottom: 40px; display: flex; align-items: center; justify-content: space-between;">
    <div style="max-width: 50%;">
        <h1 style="font-size: 40px; font-weight: bold; color: #333; margin-bottom: 16px;">Super savings on sneakers</h1>
        <p style="font-size: 18px; color: #333; margin-bottom: 24px;">Up to 50% off top styles from Nike, adidas, and more.</p>
        <a href="#" style="display: inline-block; padding: 12px 24px; background-color: #3665f3; color: white; text-decoration: none; font-weight: bold; border-radius: 24px;">Shop now &rarr;</a>
    </div>
    <div>
        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&w=400&q=80" alt="Sneakers" style="border-radius: 8px; max-height: 250px;" />
    </div>
</div>

<!-- Category shortcuts -->
<div class="ebay-categories" style="margin-bottom: 40px;">
    <h2 style="font-size: 24px; font-weight: bold; margin-bottom: 24px;">Explore Popular Categories</h2>
    <div style="display: flex; gap: 24px; overflow-x: auto; padding-bottom: 16px;">
        @if (Model != null && Model.Categories != null && Model.Categories.Any())
        {
            foreach (var category in Model.Categories)
            {
                <a href="#" style="display: flex; flex-direction: column; align-items: center; text-decoration: none; color: #333; min-width: 120px;">
                    <div style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; margin-bottom: 12px; background-color: #e5e5e5; display: flex; align-items: center; justify-content: center;">
                        <span style="font-size: 32px; font-weight: bold; color: #707070; text-transform: uppercase;">
                            @(string.IsNullOrEmpty(category.Name) ? "?" : category.Name.Substring(0, 1))
                        </span>
                    </div>
                    <span style="font-weight: bold; text-align: center;">@category.Name</span>
                </a>
            }
        }
        else
        {
            <p style="color: #707070;">No categories available from server.</p>
        }
    </div>
</div>

<!-- External Products section -->
<div class="ebay-products" style="margin-bottom: 40px;">
    <h2 style="font-size: 24px; font-weight: bold; margin-bottom: 24px;">Daily Deals</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 24px;">
        @if (Model != null && Model.Products != null && Model.Products.Any())
        {
            foreach (var product in Model.Products)
            {
                <a href="/Product/Details/@product.Id" style="width: calc(20% - 20px); text-decoration: none; color: #333; display: flex; flex-direction: column;">
                    <div style="aspect-ratio: 1; background-color: #f7f7f7; border-radius: 8px; margin-bottom: 12px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(product.ThumbnailUrl))
                        {
                            <img src="@product.ThumbnailUrl" alt="@product.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <i class="bi bi-box" style="font-size: 40px; color: #ccc;"></i>
                        }
                    </div>
                    <h3 style="font-size: 16px; margin: 0 0 4px 0; font-weight: normal; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@product.Title</h3>
                    <div style="font-size: 18px; font-weight: bold;">$@product.Price.ToString("0.00")</div>
                    <div style="font-size: 12px; color: #707070; margin-top: 4px;">Free shipping</div>
                </a>
            }
        }
        else
        {
            <p style="color: #707070;">No products available from server.</p>
        }
    </div>
</div>
